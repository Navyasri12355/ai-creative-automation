# ── Supabase (FREE — https://supabase.com) ────────────────────────────────
# Create a free project at https://supabase.com (no credit card needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── AI (FREE — Groq) ─────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com/keys
# Free tier: 30 requests/min, 14,400 requests/day, no credit card
# Uses llama-3.3-70b-versatile (super fast inference)
# Leave blank to use the offline text generation fallback
GROQ_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── App ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development             # development | production
FRONTEND_URL=http://localhost:3000

# ── COST SUMMARY ──────────────────────────────────────────────────────────
# Supabase:        FREE (500MB DB, 1GB storage, 50K auth users)
# Groq:            FREE (30 RPM, 14,400 RPD, llama-3.3-70b)
# Pollinations.ai: FREE (unlimited, no API key needed — used for images)
# Vercel:          FREE (frontend hosting)
# Total monthly cost: ₹0 / $0
